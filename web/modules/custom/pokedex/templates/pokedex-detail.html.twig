{#
/**
 * @file
 * Template para el detalle de un Pokémon.
 *
 * Variables disponibles:
 * - status: Estado de la carga ('success', 'error').
 * - pokemon: Array con datos del Pokémon (id, name, sprite, types, height, weight).
 * - error_message: Mensaje de error si status es 'error'.
 * - page: Número de página desde donde se accedió.
 */
#}

{{ attach_library('pokedex/pokedex_detail_libraries') }}

<div class="pokemon-detail-container">
  {% if status == 'error' %}
    <div class="pokemon-error">
      <div class="error-icon">⚠️</div>
      <h2>Error al cargar el Pokémon</h2>
      <p>{{ error_message|default('No se pudo obtener la información del Pokémon.') }}</p>
      <div class="error-actions">
        <a href="{{ path('pokedex.list') }}?page={{ page }}" class="btn-back">← Volver al listado</a>
        <a href="{{ url('<current>') }}" class="btn-retry">Reintentar</a>
      </div>
    </div>

  {% else %}
    <div class="pokemon-detail-header">
      <a href="{{ path('pokedex.list') }}?page={{ page }}" class="btn-back-simple">
        <span class="pokeball-button">Volver</span>
      </a>
    </div>

    <div class="pokemon-detail-card {% if pokemon.types %}pokemon-card-{{ pokemon.types[0] }}{% endif %}">
      <div class="pokemon-detail-image">
        {% if pokemon.sprite %}
          <img src="{{ pokemon.sprite }}" alt="{{ pokemon.name }}" />
        {% else %}
          <div class="no-image">Sin imagen</div>
        {% endif %}
      </div>

      <div class="pokemon-detail-info">
        <span class="pokemon-detail-id">#{{ pokemon.id }}</span>
        <h1 class="pokemon-detail-name">{{ pokemon.name|capitalize }}</h1>

        <div class="pokemon-types">
          <strong>Tipos:</strong>
          <div class="types-list">
            {% for type in pokemon.types %}
              <span class="type-badge type-{{ type }}">{{ type|capitalize }}</span>
            {% endfor %}
          </div>
        </div>

        <div class="pokemon-stats">
          <div class="stat-item">
            <span class="stat-label">Altura:</span>
            <span class="stat-value">{{ (pokemon.height / 10)|number_format(1) }} m</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Peso:</span>
            <span class="stat-value">{{ (pokemon.weight / 10)|number_format(1) }} kg</span>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>
