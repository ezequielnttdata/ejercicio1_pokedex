{#
/**
 * @file
 * Template para el detalle de un Pokémon.
 *
 * Variables disponibles:
 * - status: Estado de la carga ('success', 'error').
 * - pokemon: Array con datos del Pokémon (id, name, sprite, types, height, weight).
 * - error_message: Mensaje de error si status es 'error'.
 * - page: Número de página desde donde se accedió.
 */
#}

<div class="pokemon-detail-container">
  {% if status == 'error' %}
    <div class="pokemon-error">
      <div class="error-icon">⚠️</div>
      <h2>Error al cargar el Pokémon</h2>
      <p>{{ error_message|default('No se pudo obtener la información del Pokémon.') }}</p>
      <div class="error-actions">
        <a href="{{ path('pokedex.list') }}?page={{ page }}" class="btn-back">← Volver al listado</a>
        <a href="{{ url('<current>') }}" class="btn-retry">Reintentar</a>
      </div>
    </div>

  {% else %}
    <div class="pokemon-detail-header">
      <a href="{{ path('pokedex.list') }}?page={{ page }}" class="btn-back-simple">
        <span class="pokeball-button">Volver</span>
      </a>
    </div>

    <div class="pokemon-detail-card {% if pokemon.types %}pokemon-card-{{ pokemon.types[0] }}{% endif %}">
      <div class="pokemon-detail-image">
        {% if pokemon.sprite %}
          <img src="{{ pokemon.sprite }}" alt="{{ pokemon.name }}" />
        {% else %}
          <div class="no-image">Sin imagen</div>
        {% endif %}
      </div>

      <div class="pokemon-detail-info">
        <span class="pokemon-detail-id">#{{ pokemon.id }}</span>
        <h1 class="pokemon-detail-name">{{ pokemon.name|capitalize }}</h1>

        <div class="pokemon-types">
          <strong>Tipos:</strong>
          <div class="types-list">
            {% for type in pokemon.types %}
              <span class="type-badge type-{{ type }}">{{ type|capitalize }}</span>
            {% endfor %}
          </div>
        </div>

        <div class="pokemon-stats">
          <div class="stat-item">
            <span class="stat-label">Altura:</span>
            <span class="stat-value">{{ (pokemon.height / 10)|number_format(1) }} m</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Peso:</span>
            <span class="stat-value">{{ (pokemon.weight / 10)|number_format(1) }} kg</span>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>

<style>
.pokemon-detail-container {
  max-width: 800px;
  margin: 0 auto;
  padding: 20px;
}

.pokemon-detail-header {
  margin-bottom: 20px;
}

.btn-back-simple {
  display: inline-block;
  text-decoration: none;
  transition: all 0.3s ease;
}

.btn-back-simple:hover {
  transform: scale(1.1);
  filter: brightness(1.1);
}

.pokeball-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120px;
  height: 120px;
  border-radius: 50%;
  position: relative;
  background: linear-gradient(to bottom, #dc0a2d 0%, #dc0a2d 45%, #000 45%, #000 55%, #fff 55%, #fff 100%);
  border: 8px solid #000;
  font-weight: 900;
  font-size: 1.3em;
  color: #fff;
  text-shadow: 
    3px 3px 6px rgba(0, 0, 0, 1),
    -1px -1px 3px rgba(0, 0, 0, 0.8),
    1px 1px 2px rgba(0, 0, 0, 0.9);
  cursor: pointer;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
  letter-spacing: 0.5px;
  z-index: 1;
}

.pokeball-button::before {
  content: '';
  position: absolute;
  width: 45px;
  height: 45px;
  background: #000;
  border-radius: 50%;
  border: 5px solid #000;
  z-index: -2;
}

.pokeball-button::after {
  content: '';
  position: absolute;
  width: 25px;
  height: 25px;
  background: #fff;
  border-radius: 50%;
  border: 3px solid #000;
  z-index: -1;
}

.pokemon-detail-card {
  background: #fff;
  border: 2px solid #e0e0e0;
  border-radius: 15px;
  padding: 30px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  position: relative;
  overflow: hidden;
}

.pokemon-detail-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.1;
  z-index: 0;
}

.pokemon-detail-card > * {
  position: relative;
  z-index: 1;
}

/* Fondos de color según tipo */
.pokemon-card-normal::before { background: linear-gradient(135deg, #A8A878 0%, #C8C8A8 100%); }
.pokemon-card-fire::before { background: linear-gradient(135deg, #F08030 0%, #F8A060 100%); }
.pokemon-card-water::before { background: linear-gradient(135deg, #6890F0 0%, #98B8F8 100%); }
.pokemon-card-electric::before { background: linear-gradient(135deg, #F8D030 0%, #FCE860 100%); }
.pokemon-card-grass::before { background: linear-gradient(135deg, #78C850 0%, #A8D880 100%); }
.pokemon-card-ice::before { background: linear-gradient(135deg, #98D8D8 0%, #C8E8E8 100%); }
.pokemon-card-fighting::before { background: linear-gradient(135deg, #C03028 0%, #D85850 100%); }
.pokemon-card-poison::before { background: linear-gradient(135deg, #A040A0 0%, #C068C0 100%); }
.pokemon-card-ground::before { background: linear-gradient(135deg, #E0C068 0%, #E8D098 100%); }
.pokemon-card-flying::before { background: linear-gradient(135deg, #A890F0 0%, #C8B8F8 100%); }
.pokemon-card-psychic::before { background: linear-gradient(135deg, #F85888 0%, #F888B0 100%); }
.pokemon-card-bug::before { background: linear-gradient(135deg, #A8B820 0%, #C8D850 100%); }
.pokemon-card-rock::before { background: linear-gradient(135deg, #B8A038 0%, #D8C068 100%); }
.pokemon-card-ghost::before { background: linear-gradient(135deg, #705898 0%, #9880C0 100%); }
.pokemon-card-dragon::before { background: linear-gradient(135deg, #7038F8 0%, #9868F8 100%); }
.pokemon-card-dark::before { background: linear-gradient(135deg, #705848 0%, #988070 100%); }
.pokemon-card-steel::before { background: linear-gradient(135deg, #B8B8D0 0%, #D8D8E8 100%); }
.pokemon-card-fairy::before { background: linear-gradient(135deg, #EE99AC 0%, #F8C0D0 100%); }

.pokemon-detail-image {
  margin-bottom: 20px;
}

.pokemon-detail-image img {
  width: 200px;
  height: 200px;
  object-fit: contain;
}

.no-image {
  width: 200px;
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  border-radius: 10px;
  color: #999;
}

.pokemon-detail-info {
  text-align: center;
  width: 100%;
}

.pokemon-detail-id {
  display: inline-block;
  background: rgba(255, 255, 255, 0.9);
  padding: 5px 15px;
  border-radius: 15px;
  font-size: 1em;
  color: #333;
  font-weight: bold;
  margin-bottom: 10px;
  border: 2px solid rgba(0, 0, 0, 0.1);
}

.pokemon-detail-name {
  font-size: 2.5em;
  color: #222;
  margin: 10px 0 20px 0;
  text-shadow: 1px 1px 2px rgba(255, 255, 255, 0.5);
  font-weight: 800;
}

.pokemon-types {
  margin: 20px 0;
  padding: 15px;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 10px;
  border: 2px solid rgba(0, 0, 0, 0.05);
}

.pokemon-types strong {
  display: block;
  margin-bottom: 10px;
  color: #333;
  font-weight: 700;
}

.types-list {
  display: flex;
  justify-content: center;
  gap: 10px;
  flex-wrap: wrap;
}

.type-badge {
  padding: 5px 15px;
  border-radius: 20px;
  color: white;
  font-weight: bold;
  font-size: 0.9em;
  text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
  border: 2px solid rgba(255, 255, 255, 0.3);
}

.type-normal { background: #A8A878; }
.type-fire { background: #F08030; }
.type-water { background: #6890F0; }
.type-electric { background: #F8D030; color: #333; }
.type-grass { background: #78C850; }
.type-ice { background: #98D8D8; }
.type-fighting { background: #C03028; }
.type-poison { background: #A040A0; }
.type-ground { background: #E0C068; }
.type-flying { background: #A890F0; }
.type-psychic { background: #F85888; }
.type-bug { background: #A8B820; }
.type-rock { background: #B8A038; }
.type-ghost { background: #705898; }
.type-dragon { background: #7038F8; }
.type-dark { background: #705848; }
.type-steel { background: #B8B8D0; }
.type-fairy { background: #EE99AC; }

.pokemon-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-top: 20px;
  width: 100%;
}

.stat-item {
  background: rgba(255, 255, 255, 0.7);
  padding: 15px;
  border-radius: 10px;
  text-align: center;
  border: 2px solid rgba(0, 0, 0, 0.05);
}

.stat-label {
  display: block;
  color: #333;
  font-weight: 700;
  margin-bottom: 5px;
  font-size: 0.95em;
}

.stat-value {
  display: block;
  font-size: 1.5em;
  color: #111;
  font-weight: 800;
}

.pokemon-error {
  text-align: center;
  padding: 50px 20px;
  background: #f9f9f9;
  border-radius: 10px;
  margin: 40px 0;
}

.error-icon {
  font-size: 4em;
  margin-bottom: 20px;
}

.pokemon-error h2 {
  color: #333;
  margin-bottom: 15px;
}

.pokemon-error p {
  color: #666;
  margin-bottom: 20px;
}

.error-actions {
  display: flex;
  justify-content: center;
  gap: 15px;
  flex-wrap: wrap;
}

.btn-back, .btn-retry {
  display: inline-block;
  background: #3b4cca;
  color: white;
  padding: 10px 20px;
  border-radius: 5px;
  text-decoration: none;
  transition: background 0.2s;
}

.btn-back:hover, .btn-retry:hover {
  background: #2a3a9a;
}

@media (max-width: 600px) {
  .pokemon-stats {
    grid-template-columns: 1fr;
  }
  
  .pokemon-detail-name {
    font-size: 2em;
  }
}
</style>
