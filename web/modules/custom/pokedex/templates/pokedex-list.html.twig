{#
/**
 * @file
 * Template para el listado de Pokémon.
 *
 * Variables disponibles:
 * - status: Estado de la carga ('success', 'error', 'empty', 'not_found').
 * - items: Array de Pokémon con 'id', 'name' y 'types'.
 * - page: Número de página actual.
 * - has_previous: Boolean si hay página anterior.
 * - has_next: Boolean si hay página siguiente.
 * - error_message: Mensaje de error si status es 'error'.
 * - total_count: Total de Pokémon disponibles.
 * - search_term: Término de búsqueda actual.
 * - type_filter: Tipo filtrado actual.
 * - available_types: Array de tipos disponibles.
 */
#}

{{ attach_library('pokedex/pokedex_libraries') }}

<div class="pokedex-container">
  <h1 class="pokedex-title">Pokédex</h1>
  
  {# Contenedor de filtros #}
  <div class="filters-container">
    {# Formulario de búsqueda #}
    <form method="get" action="{{ path('pokedex.list') }}" class="search-form">
      <input type="hidden" name="page" value="{{ page }}" />
      {% if type_filter %}
        <input type="hidden" name="type" value="{{ type_filter }}" />
      {% endif %}
      <input 
        type="text" 
        name="search" 
        placeholder="Buscar por nombre o ID..." 
        class="search-input"
        value="{{ search_term }}"
      />
      <button type="submit" class="search-button">
        <span class="pokeball-btn">Buscar</span>
      </button>
    </form>

    {# Filtro por tipo #}
    <form method="get" action="{{ path('pokedex.list') }}" class="type-filter-form">
      <select name="type" class="type-select" onchange="this.form.submit()">
        <option value="">Todos los tipos</option>
        {% for type in available_types %}
          <option value="{{ type }}" {% if type_filter == type %}selected{% endif %}>
            {{ type|capitalize }}
          </option>
        {% endfor %}
      </select>
    </form>

    {# Botón para limpiar filtros #}
    {% if search_term or type_filter %}
      <a href="{{ path('pokedex.list') }}?page={{ page }}" class="clear-filters">
        ✕ Limpiar filtros
      </a>
    {% endif %}
  </div>
  
  {% if status == 'not_found' %}
    <div class="pokemon-not-found">
      <div class="not-found-icon">🔍</div>
      <h2>Pokémon no encontrado</h2>
      <p>No se encontró ningún Pokémon con el nombre o ID: <strong>{{ search_term }}</strong></p>
      <p class="help-text">Intenta buscar por nombre (ej: "pikachu") o por ID (ej: "25")</p>
      <a href="{{ path('pokedex.list') }}?page={{ page }}" class="btn-back-list">← Volver al listado</a>
    </div>

  {% elseif status == 'error' %}
    <div class="pokedex-error">
      <div class="error-icon">⚠️</div>
      <h2>Error al cargar datos</h2>
      <p>{{ error_message|default('No se pudo conectar con la API de Pokémon.') }}</p>
      <a href="{{ path('pokedex.list') }}" class="btn-retry">Reintentar</a>
    </div>

  {% elseif status == 'empty' %}
    <div class="pokedex-empty">
      <div class="empty-icon">🔍</div>
      <h2>No hay resultados</h2>
      <p>No se encontraron Pokémon{% if type_filter %} del tipo <strong>{{ type_filter }}</strong>{% endif %} en esta página.</p>
      <a href="{{ path('pokedex.list') }}" class="btn-back">Volver al inicio</a>
    </div>

  {% else %}
    <div class="pokedex-info">
      <p>
        Total de Pokémon: <strong>{{ total_count }}</strong> | Página: <strong>{{ page }}</strong>
        {% if type_filter %}
          | Filtro: <strong class="active-filter">{{ type_filter|capitalize }}</strong>
        {% endif %}
      </p>
    </div>

    <div class="pokedex-grid">
      {% for item in items %}
        {% set types = item.types|default([]) %}
        {% set type_count = types|length %}
        
        {# Mapeo de colores por tipo #}
        {% set type_colors = {
          'normal': '#A8A878',
          'fire': '#F08030',
          'water': '#6890F0',
          'electric': '#F8D030',
          'grass': '#78C850',
          'ice': '#98D8D8',
          'fighting': '#C03028',
          'poison': '#A040A0',
          'ground': '#E0C068',
          'flying': '#A890F0',
          'psychic': '#F85888',
          'bug': '#A8B820',
          'rock': '#B8A038',
          'ghost': '#705898',
          'dragon': '#7038F8',
          'dark': '#705848',
          'steel': '#B8B8D0',
          'fairy': '#EE99AC'
        } %}
        
        {# Generar gradiente dinámico basado en los tipos #}
        {% set background_style = '' %}
        {% if type_count == 1 and types[0] %}
          {% set color1 = type_colors[types[0]]|default('#e0e0e0') %}
          {% set background_style = 'background: linear-gradient(135deg, ' ~ color1 ~ ' 0%, ' ~ color1 ~ 'CC 100%) !important;' %}
        {% elseif type_count == 2 %}
          {% set color1 = type_colors[types[0]]|default('#e0e0e0') %}
          {% set color2 = type_colors[types[1]]|default('#e0e0e0') %}
          {% set background_style = 'background: linear-gradient(135deg, ' ~ color1 ~ ' 0%, ' ~ color1 ~ ' 50%, ' ~ color2 ~ ' 50%, ' ~ color2 ~ ' 100%) !important;' %}
        {% endif %}
        
        {# Preparar clases CSS para los tipos #}
        {% set type_classes = [] %}
        {% for type in types %}
          {% set type_classes = type_classes|merge(['type-' ~ type]) %}
        {% endfor %}
        
        <a href="{{ path('pokedex.detail', {'pokemon': item.name}) }}?page={{ page }}" 
           class="pokemon-card {{ type_classes|join(' ') }}" 
           data-type-count="{{ type_count }}"
           style="{{ background_style }}">
          <div class="pokemon-image">
            <img 
              src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/{{ item.id }}.png" 
              alt="{{ item.name }}"
              loading="lazy"
            />
          </div>
          <div class="pokemon-info">
            <span class="pokemon-id">#{{ '%03d'|format(item.id) }}</span>
            <h3 class="pokemon-name">{{ item.name|capitalize }}</h3>
            
            {# Mostrar badges de tipos #}
            {% if types is not empty %}
              <div class="pokemon-types">
                {% for type in types %}
                  <span class="type-badge type-badge-{{ type }}">{{ type }}</span>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>

    <nav class="pokedex-pagination">
      {% if has_previous %}
        <a href="?page={{ page - 1 }}{% if type_filter %}&type={{ type_filter }}{% endif %}" class="btn-pagination btn-prev">
          <span class="pokeball-btn">Anterior</span>
        </a>
      {% else %}
        <span class="btn-pagination btn-disabled">← Anterior</span>
      {% endif %}

      <span class="pagination-info">Página {{ page }}</span>

      {% if has_next %}
        <a href="?page={{ page + 1 }}{% if type_filter %}&type={{ type_filter }}{% endif %}" class="btn-pagination btn-next">
          <span class="pokeball-btn">Siguiente</span>
        </a>
      {% else %}
        <span class="btn-pagination btn-disabled">Siguiente →</span>
      {% endif %}
    </nav>
  {% endif %}
</div>


